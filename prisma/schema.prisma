generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("viewer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tableName  String
  recordId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([tableName, recordId, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Entity {
  id        Int       @id @default(autoincrement())
  name      String
  type      String    // "company" | "person"
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: entities_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("entities")
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  taxCode   String?
  phone     String?
  address   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: suppliers_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("suppliers")
}

model Contractor {
  id        Int       @id @default(autoincrement())
  name      String
  leader    String?
  contact   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: contractors_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("contractors")
}

model Project {
  id            Int               @id @default(autoincrement())
  code          String
  name          String
  ownerInvestor String?
  contractValue Decimal?          @db.Decimal(18, 2)
  startDate     DateTime?
  endDate       DateTime?
  status        String            @default("active")
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  categories ProjectCategory[]

  // Partial unique enforced via raw SQL: projects_code_active_unique WHERE "deletedAt" IS NULL
  @@index([code])
  @@map("projects")
}

model ProjectCategory {
  id        Int       @id @default(autoincrement())
  projectId Int
  code      String
  name      String
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  // Partial unique enforced via raw SQL: project_categories_projectid_code_active_unique WHERE "deletedAt" IS NULL
  @@index([projectId, code])
  @@map("project_categories")
}

model Item {
  id        Int       @id @default(autoincrement())
  code      String
  name      String
  unit      String
  type      String    // "material" | "labor" | "machine"
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: items_code_active_unique WHERE "deletedAt" IS NULL
  @@index([code])
  @@map("items")
}
