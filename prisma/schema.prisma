generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("viewer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tableName  String
  recordId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([tableName, recordId, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Entity {
  id        Int       @id @default(autoincrement())
  name      String
  type      String    // "company" | "person"
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: entities_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("entities")
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  taxCode   String?
  phone     String?
  address   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: suppliers_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("suppliers")
}

model Contractor {
  id        Int       @id @default(autoincrement())
  name      String
  leader    String?
  contact   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: contractors_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("contractors")
}

model Project {
  id            Int               @id @default(autoincrement())
  code          String
  name          String
  ownerInvestor String?
  contractValue Decimal?          @db.Decimal(18, 2)
  startDate     DateTime?
  endDate       DateTime?
  status        String            @default("active")
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  categories ProjectCategory[]

  // Partial unique enforced via raw SQL: projects_code_active_unique WHERE "deletedAt" IS NULL
  @@index([code])
  @@map("projects")
}

model ProjectCategory {
  id        Int       @id @default(autoincrement())
  projectId Int
  code      String
  name      String
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  // Partial unique enforced via raw SQL: project_categories_projectid_code_active_unique WHERE "deletedAt" IS NULL
  @@index([projectId, code])
  @@map("project_categories")
}

model Item {
  id        Int       @id @default(autoincrement())
  code      String
  name      String
  unit      String
  type      String    // "material" | "labor" | "machine"
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: items_code_active_unique WHERE "deletedAt" IS NULL
  @@index([code])
  @@map("items")
}

// ─── Project Management Models ───────────────────────────────────────────────

model ProjectSchedule {
  id          Int       @id @default(autoincrement())
  projectId   Int
  categoryId  Int
  taskName    String
  planStart   DateTime
  planEnd     DateTime
  actualStart DateTime?
  actualEnd   DateTime?
  pctComplete Decimal   @default(0) @db.Decimal(5, 4)
  status      String    @default("pending") // pending|in_progress|done|delayed
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  @@index([projectId])
  @@map("project_schedules")
}

model ProjectAcceptance {
  id               Int       @id @default(autoincrement())
  projectId        Int
  categoryId       Int
  checkItem        String
  planEnd          DateTime?
  actualEnd        DateTime?
  inspector        String?
  result           String?   // "pass|fail|partial"
  defectCount      Int       @default(0)
  fixRequest       String?
  acceptedAt       DateTime?
  amountCdtVnd     Decimal   @default(0) @db.Decimal(18, 2)
  amountInternalVnd Decimal  @default(0) @db.Decimal(18, 2)
  acceptanceBatch  String?
  note             String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())

  @@index([projectId])
  @@map("project_acceptances")
}

model ProjectEstimate {
  id         Int       @id @default(autoincrement())
  projectId  Int
  categoryId Int
  itemCode   String
  itemName   String
  unit       String
  qty        Decimal   @db.Decimal(18, 4)
  unitPrice  Decimal   @db.Decimal(18, 2)
  totalVnd   Decimal   @default(0) @db.Decimal(18, 2) // qty * unitPrice, computed on write
  note       String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  @@index([projectId, categoryId])
  @@map("project_estimates")
}

model ProjectChangeOrder {
  id                  Int       @id @default(autoincrement())
  projectId           Int
  date                DateTime
  coCode              String
  description         String
  reason              String?
  categoryId          Int?
  itemCode            String?
  costImpactVnd       Decimal   @default(0) @db.Decimal(18, 2)
  scheduleImpactDays  Int       @default(0)
  approvedBy          String?
  status              String    @default("pending") // pending|approved|rejected
  newItemName         String?
  newUnit             String?
  newQty              Decimal?  @db.Decimal(18, 4)
  newUnitPrice        Decimal?  @db.Decimal(18, 2)
  note                String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now())

  @@index([projectId])
  @@map("project_change_orders")
}

model ProjectTransaction {
  id              Int       @id @default(autoincrement())
  projectId       Int
  date            DateTime
  transactionType String    // lay_hang|nhan_cong|may_moc
  categoryId      Int
  itemCode        String
  itemName        String
  partyName       String?
  qty             Decimal   @db.Decimal(18, 4)
  unit            String
  unitPriceHd     Decimal   @default(0) @db.Decimal(18, 2)
  unitPriceTt     Decimal   @default(0) @db.Decimal(18, 2)
  amountHd        Decimal   @default(0) @db.Decimal(18, 2)
  amountTt        Decimal   @default(0) @db.Decimal(18, 2)
  invoiceNo       String?
  status          String    @default("pending") // pending|approved|paid
  note            String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  @@index([projectId, categoryId])
  @@map("project_transactions")
}

model ProjectContract {
  id          Int       @id @default(autoincrement())
  projectId   Int
  docName     String
  docType     String    // contract|license
  partyName   String?
  valueVnd    Decimal?  @db.Decimal(18, 2)
  signedDate  DateTime?
  expiryDate  DateTime?
  status      String    @default("active") // active|expired|terminated
  storage     String?
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  @@index([projectId])
  @@map("project_contracts")
}

model Project3WayCashflow {
  id            Int       @id @default(autoincrement())
  projectId     Int
  date          DateTime
  flowDirection String    // cdt_to_cty|cty_to_doi|doi_to_cty|cty_to_cdt|doi_refund
  category      String    // tam_ung|nop_lai|thanh_toan|hoan_ung
  payerName     String
  payeeName     String
  amountVnd     Decimal   @db.Decimal(18, 2)
  batch         String?
  refDoc        String?
  note          String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())

  @@index([projectId, date])
  @@map("project_3way_cashflows")
}

model ProjectSettings {
  projectId          Int     @id
  vatPct             Decimal @default(0.1) @db.Decimal(5, 4)
  normYellowThreshold Decimal @default(0.8) @db.Decimal(5, 4)
  normRedThreshold   Decimal @default(0.95) @db.Decimal(5, 4)
  contractWarningDays Int    @default(90)
  managementFeePct   Decimal @default(0.05) @db.Decimal(5, 4)
  teamSharePct       Decimal @default(0.85) @db.Decimal(5, 4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())

  @@map("project_settings")
}
