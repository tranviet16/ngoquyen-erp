generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("viewer")
  departmentId  Int?
  isLeader      Boolean  @default(false)
  isDirector    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions   Session[]
  accounts   Account[]
  auditLogs  AuditLog[]
  department Department? @relation(fields: [departmentId], references: [id])

  coordinationFormsCreated  CoordinationForm[]         @relation("CFormCreator")
  coordinationFormsApproved CoordinationFormApproval[] @relation("CFormApprover")

  tasksCreated  Task[]         @relation("TaskCreator")
  tasksAssigned Task[]         @relation("TaskAssignee")
  notifications Notification[]

  taskComments    TaskComment[]    @relation("TaskCommentAuthor")
  taskAttachments TaskAttachment[] @relation("TaskAttachmentUploader")

  deptAccess    UserDeptAccess[] @relation("UserAccess")
  accessGranted UserDeptAccess[] @relation("AccessGranter")

  modulePermissions         ModulePermission[]  @relation("ModulePermissionUser")
  modulePermissionsGranted  ModulePermission[]  @relation("ModulePermissionGranter")
  projectPermissions        ProjectPermission[] @relation("ProjectPermissionUser")
  projectPermissionsGranted ProjectPermission[] @relation("ProjectPermissionGranter")
  projectGrantAll           ProjectGrantAll?    @relation("ProjectGrantAllUser")
  projectGrantAllGranted    ProjectGrantAll[]   @relation("ProjectGrantAllGranter")

  @@index([departmentId])
  @@map("users")
}

model Department {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]

  coordinationFormsAsCreator  CoordinationForm[] @relation("CFormCreatorDept")
  coordinationFormsAsExecutor CoordinationForm[] @relation("CFormExecutorDept")

  tasks      Task[]
  userAccess UserDeptAccess[]

  @@map("departments")
}

model UserDeptAccess {
  id        Int      @id @default(autoincrement())
  userId    String
  deptId    Int
  level     String
  grantedAt DateTime @default(now())
  grantedBy String?

  user    User       @relation("UserAccess", fields: [userId], references: [id], onDelete: Cascade)
  dept    Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  granter User?      @relation("AccessGranter", fields: [grantedBy], references: [id])

  @@unique([userId, deptId])
  @@index([userId])
  @@index([deptId])
  @@map("user_dept_access")
}

model CoordinationForm {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  creatorId      String
  creatorDeptId  Int
  executorDeptId Int
  content        String
  priority       String    @default("trung_binh")
  deadline       DateTime?
  status         String    @default("draft")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  submittedAt    DateTime?
  closedAt       DateTime?

  creator      User                       @relation("CFormCreator", fields: [creatorId], references: [id])
  creatorDept  Department                 @relation("CFormCreatorDept", fields: [creatorDeptId], references: [id])
  executorDept Department                 @relation("CFormExecutorDept", fields: [executorDeptId], references: [id])
  approvals    CoordinationFormApproval[]
  task         Task?

  @@index([executorDeptId, status])
  @@index([creatorId])
  @@index([status])
  @@map("coordination_forms")
}

model CoordinationFormApproval {
  id         Int      @id @default(autoincrement())
  formId     Int
  step       String
  approverId String
  action     String
  comment    String?
  signedAt   DateTime @default(now())

  form     CoordinationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  approver User             @relation("CFormApprover", fields: [approverId], references: [id])

  @@index([formId])
  @@index([approverId])
  @@map("coordination_form_approvals")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tableName  String
  recordId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([tableName, recordId, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Entity {
  id        Int       @id @default(autoincrement())
  name      String
  type      String // "company" | "person"
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: entities_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("entities")
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  taxCode   String?
  phone     String?
  address   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: suppliers_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("suppliers")
}

model Contractor {
  id        Int       @id @default(autoincrement())
  name      String
  leader    String?
  contact   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: contractors_name_active_unique WHERE "deletedAt" IS NULL
  @@index([name])
  @@map("contractors")
}

model Project {
  id            Int       @id @default(autoincrement())
  code          String
  name          String
  ownerInvestor String?
  contractValue Decimal?  @db.Decimal(18, 2)
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("active")
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categories      ProjectCategory[]
  userPermissions ProjectPermission[]

  // Partial unique enforced via raw SQL: projects_code_active_unique WHERE "deletedAt" IS NULL
  @@index([code])
  @@map("projects")
}

model ProjectCategory {
  id        Int       @id @default(autoincrement())
  projectId Int
  code      String
  name      String
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  // Partial unique enforced via raw SQL: project_categories_projectid_code_active_unique WHERE "deletedAt" IS NULL
  @@index([projectId, code])
  @@map("project_categories")
}

model Item {
  id        Int       @id @default(autoincrement())
  code      String
  name      String
  unit      String
  type      String // "material" | "labor" | "machine"
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique enforced via raw SQL: items_code_active_unique WHERE "deletedAt" IS NULL
  @@index([code])
  @@map("items")
}

// ─── Project Management Models ───────────────────────────────────────────────

model ProjectSchedule {
  id          Int       @id @default(autoincrement())
  projectId   Int
  categoryId  Int
  taskName    String
  planStart   DateTime
  planEnd     DateTime
  actualStart DateTime?
  actualEnd   DateTime?
  pctComplete Decimal   @default(0) @db.Decimal(5, 4)
  status      String    @default("pending") // pending|in_progress|done|delayed
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([importRunId])
  @@map("project_schedules")
}

model ProjectAcceptance {
  id                Int       @id @default(autoincrement())
  projectId         Int
  categoryId        Int
  checkItem         String
  planEnd           DateTime?
  actualEnd         DateTime?
  inspector         String?
  result            String? // "pass|fail|partial"
  defectCount       Int       @default(0)
  fixRequest        String?
  acceptedAt        DateTime?
  amountCdtVnd      Decimal   @default(0) @db.Decimal(18, 2)
  amountInternalVnd Decimal   @default(0) @db.Decimal(18, 2)
  acceptanceBatch   String?
  note              String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([importRunId])
  @@map("project_acceptances")
}

model ProjectEstimate {
  id         Int       @id @default(autoincrement())
  projectId  Int
  categoryId Int
  itemCode   String
  itemName   String
  unit       String
  qty        Decimal   @db.Decimal(18, 4)
  unitPrice  Decimal   @db.Decimal(18, 2)
  totalVnd   Decimal   @default(0) @db.Decimal(18, 2) // qty * unitPrice, computed on write
  note       String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId, categoryId])
  @@index([importRunId])
  @@map("project_estimates")
}

model ProjectChangeOrder {
  id                 Int       @id @default(autoincrement())
  projectId          Int
  date               DateTime
  coCode             String
  description        String
  reason             String?
  categoryId         Int?
  itemCode           String?
  costImpactVnd      Decimal   @default(0) @db.Decimal(18, 2)
  scheduleImpactDays Int       @default(0)
  approvedBy         String?
  status             String    @default("pending") // pending|approved|rejected
  newItemName        String?
  newUnit            String?
  newQty             Decimal?  @db.Decimal(18, 4)
  newUnitPrice       Decimal?  @db.Decimal(18, 2)
  note               String?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([importRunId])
  @@map("project_change_orders")
}

model ProjectTransaction {
  id              Int       @id @default(autoincrement())
  projectId       Int
  date            DateTime
  transactionType String // lay_hang|nhan_cong|may_moc
  categoryId      Int
  itemCode        String
  itemName        String
  partyName       String?
  qty             Decimal   @db.Decimal(18, 4)
  unit            String
  unitPriceHd     Decimal   @default(0) @db.Decimal(18, 2)
  unitPriceTt     Decimal   @default(0) @db.Decimal(18, 2)
  amountHd        Decimal   @default(0) @db.Decimal(18, 2)
  amountTt        Decimal   @default(0) @db.Decimal(18, 2)
  invoiceNo       String?
  status          String    @default("pending") // pending|approved|paid
  note            String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId, categoryId])
  @@index([importRunId])
  @@map("project_transactions")
}

model ProjectContract {
  id         Int       @id @default(autoincrement())
  projectId  Int
  docName    String
  docType    String // contract|license
  partyName  String?
  valueVnd   Decimal?  @db.Decimal(18, 2)
  signedDate DateTime?
  expiryDate DateTime?
  status     String    @default("active") // active|expired|terminated
  storage    String?
  note       String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([importRunId])
  @@map("project_contracts")
}

model Project3WayCashflow {
  id            Int       @id @default(autoincrement())
  projectId     Int
  date          DateTime
  flowDirection String // cdt_to_cty|cty_to_doi|doi_to_cty|cty_to_cdt|doi_refund
  category      String // tam_ung|nop_lai|thanh_toan|hoan_ung
  payerName     String
  payeeName     String
  amountVnd     Decimal   @db.Decimal(18, 2)
  batch         String?
  refDoc        String?
  note          String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([importRunId])
  @@map("project_3way_cashflows")
}

model ProjectSettings {
  projectId           Int      @id
  vatPct              Decimal  @default(0.1) @db.Decimal(5, 4)
  normYellowThreshold Decimal  @default(0.8) @db.Decimal(5, 4)
  normRedThreshold    Decimal  @default(0.95) @db.Decimal(5, 4)
  contractWarningDays Int      @default(90)
  managementFeePct    Decimal  @default(0.05) @db.Decimal(5, 4)
  teamSharePct        Decimal  @default(0.85) @db.Decimal(5, 4)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())

  @@map("project_settings")
}

// ─── Vật tư theo NCC Models (Phase 4) ────────────────────────────────────────

model SupplierDeliveryDaily {
  id          Int       @id @default(autoincrement())
  supplierId  Int
  projectId   Int?
  date        DateTime
  itemId      Int
  qty         Decimal   @db.Decimal(18, 4)
  unit        String // snapshot from Item.unit at entry time
  unitPrice   Decimal?  @db.Decimal(18, 2)
  totalAmount Decimal?  @db.Decimal(18, 2)
  cbVatTu     String? // Cán bộ vật tư
  chiHuyCt    String? // Chỉ huy công trường
  keToan      String? // Kế toán
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([supplierId, date])
  @@index([supplierId, itemId])
  @@index([importRunId])
  @@map("supplier_delivery_daily")
}

model SupplierReconciliation {
  id               Int       @id @default(autoincrement())
  supplierId       Int
  periodFrom       DateTime
  periodTo         DateTime
  openingBalance   Decimal   @db.Decimal(18, 2)
  totalIn          Decimal   @db.Decimal(18, 2)
  totalPaid        Decimal   @db.Decimal(18, 2)
  closingBalance   Decimal   @db.Decimal(18, 2)
  signedBySupplier Boolean   @default(false)
  signedDate       DateTime?
  note             String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([supplierId, periodFrom])
  @@index([importRunId])
  @@map("supplier_reconciliations")
}

// ─── Ledger Models (Phase 5 — Công nợ Vật tư / Nhân công) ───────────────────

model LedgerTransaction {
  id              Int      @id @default(autoincrement())
  ledgerType      String // "material" | "labor"
  date            DateTime
  transactionType String // "lay_hang" | "thanh_toan" | "dieu_chinh"
  entityId        Int // Chủ Thể
  partyId         Int // supplier_id (material) | contractor_id (labor)
  projectId       Int?
  itemId          Int? // null if paying total (không link item cụ thể)

  // Thực tế (TT)
  amountTt Decimal @default(0) @db.Decimal(18, 2)
  vatPctTt Decimal @default(0) @db.Decimal(5, 4)
  vatTt    Decimal @default(0) @db.Decimal(18, 2)
  totalTt  Decimal @default(0) @db.Decimal(18, 2)

  // Hóa đơn (HĐ)
  amountHd Decimal @default(0) @db.Decimal(18, 2)
  vatPctHd Decimal @default(0) @db.Decimal(5, 4)
  vatHd    Decimal @default(0) @db.Decimal(18, 2)
  totalHd  Decimal @default(0) @db.Decimal(18, 2)

  invoiceNo   String?
  invoiceDate DateTime?
  content     String?
  status      String     @default("pending") // pending|approved|paid
  note        String?
  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ledgerType, entityId, partyId, projectId, date])
  @@index([importRunId])
  @@map("ledger_transactions")
}

model LedgerOpeningBalance {
  id          Int        @id @default(autoincrement())
  ledgerType  String // "material" | "labor"
  entityId    Int // Chủ Thể
  partyId     Int // supplier_id | contractor_id
  projectId   Int?
  balanceTt   Decimal    @db.Decimal(18, 2)
  balanceHd   Decimal    @db.Decimal(18, 2)
  asOfDate    DateTime
  note        String?
  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Opening balance is set once per (ledgerType, entity, party, project) — not soft-deletable
  @@unique([ledgerType, entityId, partyId, projectId])
  @@index([importRunId])
  @@map("ledger_opening_balances")
}

model PaymentSchedule {
  // Tiến độ nộp tiền của chủ đầu tư theo từng đợt — read by tai-chinh cashflow forecast.
  id           Int       @id @default(autoincrement())
  projectId    Int
  batch        String
  planDate     DateTime
  planAmount   Decimal   @db.Decimal(18, 2)
  actualDate   DateTime?
  actualAmount Decimal?  @db.Decimal(18, 2)
  status       String    @default("pending")
  note         String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([importRunId])
  @@map("payment_schedules")
}

// ─── Tài chính NQ Models (Phase 8) ──────────────────────────────────────────

model LoanContract {
  id              Int       @id @default(autoincrement())
  lenderName      String
  principalVnd    Decimal   @db.Decimal(18, 2)
  interestRatePct Decimal   @db.Decimal(5, 4) // e.g. 0.08 = 8%/năm
  startDate       DateTime
  endDate         DateTime
  paymentSchedule String // "monthly" | "quarterly" | "bullet"
  status          String    @default("active") // active|paid_off|terminated
  contractDoc     String?
  note            String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  payments LoanPayment[]

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([status, endDate])
  @@index([importRunId])
  @@map("loan_contracts")
}

model LoanPayment {
  id             Int       @id @default(autoincrement())
  loanContractId Int
  dueDate        DateTime
  principalDue   Decimal   @db.Decimal(18, 2)
  interestDue    Decimal   @db.Decimal(18, 2)
  paidDate       DateTime?
  principalPaid  Decimal?  @db.Decimal(18, 2)
  interestPaid   Decimal?  @db.Decimal(18, 2)
  status         String    @default("pending") // pending|paid|overdue
  note           String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  loanContract LoanContract @relation(fields: [loanContractId], references: [id])

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([loanContractId, dueDate])
  @@index([dueDate, status])
  @@index([importRunId])
  @@map("loan_payments")
}

model JournalEntry {
  id                Int       @id @default(autoincrement())
  date              DateTime
  entryType         String // "thu" | "chi" | "chuyen_khoan"
  amountVnd         Decimal   @db.Decimal(18, 2)
  fromAccount       String?
  toAccount         String?
  fromAccountId     Int?
  toAccountId       Int?
  expenseCategoryId Int?
  refModule         String? // "loan" | "material" | "labor" | null
  refId             Int?
  description       String
  attachmentUrl     String?
  note              String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now())

  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  fromAccountRef  CashAccount?     @relation("JeFromAccount", fields: [fromAccountId], references: [id])
  toAccountRef    CashAccount?     @relation("JeToAccount", fields: [toAccountId], references: [id])

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([date, entryType])
  @@index([expenseCategoryId])
  @@index([importRunId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("journal_entries")
}

model CashAccount {
  id                Int       @id @default(autoincrement())
  name              String    @unique
  openingBalanceVnd Decimal   @default(0) @db.Decimal(18, 2)
  displayOrder      Int       @default(0)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now())

  jeFrom JournalEntry[] @relation("JeFromAccount")
  jeTo   JournalEntry[] @relation("JeToAccount")

  @@map("cash_accounts")
}

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  code      String
  name      String
  parentId  Int?
  level     Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())

  entries JournalEntry[]

  @@index([parentId])
  @@map("expense_categories")
}

// ─── Import Runs (Phase 9 — one-shot historical migration tracking) ──────────

model ImportRun {
  id           Int       @id @default(autoincrement())
  fileName     String
  fileHash     String // sha256 of uploaded file for idempotency check
  adapter      String // "cong-no-vat-tu" | "du-an-xay-dung" | "tai-chinh-nq" | etc
  status       String    @default("pending") // pending|preview|committed|failed
  rowsTotal    Int       @default(0)
  rowsImported Int       @default(0)
  rowsSkipped  Int       @default(0)
  errors       Json? // array of { row, message }
  mapping      Json? // user-resolved conflict mappings { sourceKey: targetId }
  createdBy    String
  createdAt    DateTime  @default(now())
  committedAt  DateTime?

  ledgerTransactions           LedgerTransaction[]
  ledgerOpeningBalances        LedgerOpeningBalance[]
  projectEstimates             ProjectEstimate[]
  projectTransactions          ProjectTransaction[]
  supplierDeliveryDaily        SupplierDeliveryDaily[]
  paymentSchedules             PaymentSchedule[]
  loanContracts                LoanContract[]
  journalEntries               JournalEntry[]
  projectSchedules             ProjectSchedule[]
  projectAcceptances           ProjectAcceptance[]
  projectChangeOrders          ProjectChangeOrder[]
  projectContracts             ProjectContract[]
  project3WayCashflows         Project3WayCashflow[]
  supplierReconciliations      SupplierReconciliation[]
  loanPayments                 LoanPayment[]
  payableReceivableAdjustments PayableReceivableAdjustment[]
  expenseClassifications       ExpenseClassification[]
  projectSupplierDebtSnapshots ProjectSupplierDebtSnapshot[]

  @@index([adapter, status])
  @@index([createdAt])
  @@map("import_runs")
}

model PayableReceivableAdjustment {
  id        Int       @id @default(autoincrement())
  date      DateTime
  partyType String // "supplier" | "contractor" | "other"
  partyName String
  projectId Int?
  type      String // "payable" | "receivable"
  amountVnd Decimal   @db.Decimal(18, 2)
  dueDate   DateTime?
  status    String    @default("pending") // pending|paid|cancelled
  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([projectId])
  @@index([importRunId])
  @@map("payable_receivable_adjustments")
}

// ─── Phân loại chi phí (separate from JournalEntry — line items per category) ──

model ExpenseClassification {
  id           Int       @id @default(autoincrement())
  date         DateTime
  categoryName String // Loại cụ thể từ file SOP
  amountVnd    Decimal   @db.Decimal(18, 2)
  description  String?
  projectId    Int?
  note         String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([categoryName])
  @@index([importRunId])
  @@map("expense_classifications")
}

// ─── Snapshot công nợ NCC theo dự án (line-item Công Nợ tab) ───────────────────

model ProjectSupplierDebtSnapshot {
  id            Int       @id @default(autoincrement())
  projectId     Int
  supplierName  String
  itemName      String?
  qty           Decimal?  @db.Decimal(18, 4)
  unit          String?
  unitPrice     Decimal?  @db.Decimal(18, 2)
  amountTaken   Decimal?  @db.Decimal(18, 2) // Đã lấy hàng (TT)
  amountPaid    Decimal?  @db.Decimal(18, 2) // Đã trả tiền (TT)
  balance       Decimal?  @db.Decimal(18, 2) // Còn nợ (TT)
  amountTakenHd Decimal?  @db.Decimal(18, 2) // Đã lấy hàng (HĐ)
  amountPaidHd  Decimal?  @db.Decimal(18, 2) // Đã trả tiền (HĐ)
  balanceHd     Decimal?  @db.Decimal(18, 2) // Còn nợ (HĐ)
  asOfDate      DateTime?
  note          String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())

  importRunId Int?
  importRun   ImportRun? @relation(fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([supplierName])
  @@index([importRunId])
  @@map("project_supplier_debt_snapshots")
}

// ─── SL-DT Independent Module (Phase 2 rewrite) ────────────────────────────
// Replaces SlDtTarget+PaymentSchedule. Lots no longer reuse Project entity.

model SlDtLot {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  lotName       String
  phaseCode     String    @default("?")
  groupCode     String    @default("?")
  sortOrder     Int       @default(0)
  estimateValue Decimal   @default(0) @db.Decimal(18, 2)
  contractValue Decimal?  @db.Decimal(18, 2)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  paymentPlan    SlDtPaymentPlan?
  monthlyInputs  SlDtMonthlyInput[]
  progressStatus SlDtProgressStatus[]

  @@index([phaseCode, groupCode, sortOrder])
  @@map("sl_dt_lots")
}

model SlDtMilestoneScore {
  id            Int      @id @default(autoincrement())
  milestoneText String   @unique
  score         Int
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("sl_dt_milestone_scores")
}

model SlDtPaymentPlan {
  id            Int      @id @default(autoincrement())
  lotId         Int      @unique
  dot1Amount    Decimal  @default(0) @db.Decimal(18, 2)
  dot1Milestone String?
  dot2Amount    Decimal  @default(0) @db.Decimal(18, 2)
  dot2Milestone String?
  dot3Amount    Decimal  @default(0) @db.Decimal(18, 2)
  dot3Milestone String?
  dot4Amount    Decimal  @default(0) @db.Decimal(18, 2)
  dot4Milestone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lot           SlDtLot  @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@map("sl_dt_payment_plans")
}

model SlDtMonthlyInput {
  id            Int      @id @default(autoincrement())
  lotId         Int
  year          Int
  month         Int
  slKeHoachKy   Decimal  @default(0) @db.Decimal(18, 2)
  slThucKyTho   Decimal  @default(0) @db.Decimal(18, 2)
  slLuyKeTho    Decimal  @default(0) @db.Decimal(18, 2)
  slTrat        Decimal  @default(0) @db.Decimal(18, 2)
  dtKeHoachKy   Decimal  @default(0) @db.Decimal(18, 2)
  dtThoKy       Decimal  @default(0) @db.Decimal(18, 2)
  dtThoLuyKe    Decimal  @default(0) @db.Decimal(18, 2)
  qtTratChua    Decimal  @default(0) @db.Decimal(18, 2)
  dtTratKy      Decimal  @default(0) @db.Decimal(18, 2)
  dtTratLuyKe   Decimal  @default(0) @db.Decimal(18, 2)
  estimateValue Decimal? @db.Decimal(18, 2)
  contractValue Decimal? @db.Decimal(18, 2)
  ghiChu        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lot           SlDtLot  @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([lotId, year, month])
  @@index([year, month])
  @@map("sl_dt_monthly_inputs")
}

model SlDtProgressStatus {
  id               Int      @id @default(autoincrement())
  lotId            Int
  year             Int
  month            Int
  milestoneText    String?
  targetMilestone  String?
  settlementStatus String?
  khungBtct        String?
  xayTuong         String?
  tratNgoai        String?
  xayTho           String?
  tratHoanThien    String?
  hoSoQuyetToan    String?
  ghiChu           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lot              SlDtLot  @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([lotId, year, month])
  @@index([year, month])
  @@map("sl_dt_progress_statuses")
}

model SlDtSubtotalLabel {
  id        Int      @id @default(autoincrement())
  scope     String
  key       String
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, key])
  @@map("sl_dt_subtotal_labels")
}

model Task {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  status        String    @default("todo")
  priority      String    @default("trung_binh")
  deadline      DateTime?
  assigneeId    String?
  deptId        Int
  creatorId     String
  sourceFormId  Int?      @unique
  parentId      Int?
  orderInColumn Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  assignee   User?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator    User              @relation("TaskCreator", fields: [creatorId], references: [id])
  dept       Department        @relation(fields: [deptId], references: [id])
  sourceForm CoordinationForm? @relation(fields: [sourceFormId], references: [id])
  parent     Task?             @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   Task[]            @relation("TaskHierarchy")

  comments    TaskComment[]
  attachments TaskAttachment[]

  @@index([deptId, status, orderInColumn])
  @@index([assigneeId, status])
  @@index([creatorId])
  @@index([parentId])
  @@map("tasks")
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  taskId    Int
  authorId  String
  body      String
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorId], references: [id])

  @@index([taskId, createdAt])
  @@index([authorId])
  @@map("task_comments")
}

model TaskAttachment {
  id         Int      @id @default(autoincrement())
  taskId     Int
  uploaderId String
  filename   String
  storedPath String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation("TaskAttachmentUploader", fields: [uploaderId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_attachments")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── ACL: Module & Project Permissions ──────────────────────────────────────

model ModulePermission {
  userId    String
  moduleKey String
  level     String // "read" | "comment" | "edit" | "admin"
  grantedAt DateTime @default(now())
  grantedBy String?

  user    User  @relation("ModulePermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  granter User? @relation("ModulePermissionGranter", fields: [grantedBy], references: [id])

  @@id([userId, moduleKey])
  @@index([userId])
  @@map("module_permissions")
}

model ProjectPermission {
  userId    String
  projectId Int
  level     String
  grantedAt DateTime @default(now())
  grantedBy String?

  user    User    @relation("ProjectPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  granter User?   @relation("ProjectPermissionGranter", fields: [grantedBy], references: [id])

  @@id([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("project_permissions")
}

model ProjectGrantAll {
  userId    String   @id
  level     String
  grantedAt DateTime @default(now())
  grantedBy String?

  user    User  @relation("ProjectGrantAllUser", fields: [userId], references: [id], onDelete: Cascade)
  granter User? @relation("ProjectGrantAllGranter", fields: [grantedBy], references: [id])

  @@map("project_grant_all")
}
