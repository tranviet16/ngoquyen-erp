# Test environment — local docker Postgres only. Non-secret local creds.
# Integration/security/performance Vitest projects + Playwright load this via dotenv.
# Uses a DEDICATED test database (ngoquyyen_erp_test) — truncateAll() wipes it, never the dev DB.
DATABASE_URL="postgresql://nqerp:nqerp_secret@localhost:5433/ngoquyyen_erp_test?schema=public"
BETTER_AUTH_SECRET="test-secret-not-used-in-prod"
BETTER_AUTH_URL="http://localhost:3000"
NODE_ENV="test"
